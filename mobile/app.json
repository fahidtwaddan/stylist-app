{
  "expo": {
    "name": "AI Stylist",
    "slug": "ai-stylist",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "aistylist",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#0a0a0a"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.aistylist.app",
      "infoPlist": {
        "NSCameraUsageDescription": "We need camera access to take your style photo",
        "NSPhotoLibraryUsageDescription": "We need photo library access to select your style photo"
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0a0a0a",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "package": "com.aistylist.app"
    },
    "plugins": [
      "expo-router",
      "expo-image-picker",
      [
        "expo-font",
        {
          "fonts": []
        }
      ]
    ]
  }
}
